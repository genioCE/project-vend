{
  "name": "corpus-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for querying a personal writing corpus",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "check": "npm run lint && npm run test",
    "start": "node dist/index.js",
    "start:api": "node dist/api-server.js",
    "backfill": "node dist/backfill-timeseries.js",
    "reprocess": "node dist/reprocess-suspect.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "duckdb": "^1.1.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
