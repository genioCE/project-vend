CORPUS_PATH=./corpus
CHROMA_PERSIST_PATH=./data/chroma
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDINGS_SERVICE_URL=http://embeddings-service:8000
ANALYSIS_SERVICE_URL=http://analysis-service:8002
ENTRY_SUMMARY_PROVIDER=ollama
STATE_LABEL_PROVIDER=ollama
# Ollama — can be local (host.docker.internal) or remote
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.18
NEO4J_USER=neo4j
# Required: change before first run.
NEO4J_PASSWORD=change-me
GRAPH_STYLE_PROFILE_PATH=/service/config/style_profile.json
GRAPH_ENTITY_ALIASES_PATH=/service/config/entity_aliases.json
GRAPH_FEEDBACK_STORE_PATH=/service/data/graphrag_feedback.json
LOG_LEVEL=info
